{
  "name": "@thinkfleet/sdk",
  "version": "0.1.0",
  "description": "ThinkFleet SDK — TypeScript client for AI Agents, Crews, Knowledge Base, and MCP Services",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:integration": "tsx test-app.ts",
    "seed:pizza": "tsx scripts/seed-pizza.ts"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "thinkfleet",
    "ai",
    "agents",
    "sdk",
    "api"
  ],
  "license": "MIT"
}
